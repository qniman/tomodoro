{
    "$schema": "https://www.schemastore.org/package.json",
    "private": true,
    "type": "module",
    "engines": {
        "node": ">=20.19.0"
    },
    "scripts": {
        "build": "vite build && vite build --config vite.pomodoro.config.js",
        "dev": "concurrently -k \"vite\" \"vite build --config vite.pomodoro.config.js --watch\"",
        "dev:host": "concurrently -k \"vite --host --strictPort\" \"vite build --config vite.pomodoro.config.js --watch\""
    },
    "devDependencies": {
        "concurrently": "^9.0.1",
        "laravel-vite-plugin": "^2.0.0",
        "vite": "^7.0.7"
    },
    "dependencies": {
        "@tiptap/core": "^2.6.6",
        "@tiptap/extension-link": "^2.6.6",
        "@tiptap/extension-placeholder": "^2.6.6",
        "@tiptap/extension-task-item": "^2.6.6",
        "@tiptap/extension-task-list": "^2.6.6",
        "@tiptap/starter-kit": "^2.6.6"
    }
}
